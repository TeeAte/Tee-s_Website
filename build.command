#!/bin/bash
cd "$(dirname "$0")"
echo "正在打包项目..."
npm run build
echo ""
echo "========================================================="
echo "✅ 打包完成！"
echo "请打开 dist 文件夹中的 worker.js 文件，全选并复制全部内容，"
echo "然后粘贴到 Cloudflare 网页端的编辑器中进行部署。"
echo "========================================================="
echo ""
read -p "按回车键退出..."
